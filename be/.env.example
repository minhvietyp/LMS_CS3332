# PostgreSQL (required by Prisma)
# Local example:
# DATABASE_URL="postgresql://lms_user:lms_password@localhost:5432/lms_db?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lms?schema=public"

# Server
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=debug
SLOW_REQUEST_THRESHOLD_MS=1000

# Required in production: long random secret for signing access JWTs.
# Example generator: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

# Refresh tokens are stored hashed in the database and delivered as httpOnly cookies.
REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_NAME=refresh_token
COOKIE_DOMAIN=

# Password hashing cost (bcrypt rounds)
BCRYPT_ROUNDS=12

# Comma-separated browser origins for credentialed CORS.
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Behind reverse proxy: forward X-Forwarded-* for correct IP-based rate limits.
TRUST_PROXY=false
JSON_BODY_LIMIT=100kb

# API rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_STRICT_WINDOW_MS=900000
AUTH_STRICT_MAX=10
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_RATE_LIMIT_MAX=120

# Optional in-memory public-read cache. Do not use for private user data.
CACHE_ENABLED=true
PUBLIC_CACHE_TTL_MS=60000

# Optional Cloudinary upload settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional SMTP/email settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@lms.local

# Prisma seed bootstrap admin account
ADMIN_SEED_NAME="System Admin"
ADMIN_SEED_EMAIL="admin@lms.local"
ADMIN_SEED_PASSWORD=

# Optional seed accounts for manual testing
INSTRUCTOR_SEED_NAME="Instructor Demo"
INSTRUCTOR_SEED_EMAIL="instructor@lms.local"
INSTRUCTOR_SEED_PASSWORD=

STUDENT_SEED_NAME="Student Demo"
STUDENT_SEED_EMAIL="student@lms.local"
STUDENT_SEED_PASSWORD=
