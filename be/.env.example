# PostgreSQL (required by Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lms?schema=public"

# Server — use HTTPS in production (TLS terminates at reverse proxy or the Node host).
PORT=3000
NODE_ENV=development

# Required in production: long random secret for signing access JWTs (e.g. openssl rand -base64 48)
JWT_ACCESS_SECRET=
# Access token lifetime (jsonwebtoken format, e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m

# Password hashing cost (bcrypt rounds)
BCRYPT_ROUNDS=12

# Refresh token stored hashed in DB; cookie is httpOnly, Secure in production
REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_NAME=refresh_token
# Optional: e.g. .example.com when API and SPA share parent domain
COOKIE_DOMAIN=

# Comma-separated browser origins (required for credentialed cookies from a SPA).
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGINS=

# Behind reverse proxy: forward X-Forwarded-* for correct IP-based rate limits
TRUST_PROXY=false

JSON_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Stricter limit for POST /api/auth/register and /api/auth/login (per IP)
AUTH_STRICT_WINDOW_MS=900000
AUTH_STRICT_MAX=10

# Prisma seed bootstrap admin account
ADMIN_SEED_NAME="System Admin"
ADMIN_SEED_EMAIL="admin@lms.local"
ADMIN_SEED_PASSWORD=

# Optional seed accounts for manual testing
INSTRUCTOR_SEED_NAME="Instructor Demo"
INSTRUCTOR_SEED_EMAIL="instructor@lms.local"
INSTRUCTOR_SEED_PASSWORD=

STUDENT_SEED_NAME="Student Demo"
STUDENT_SEED_EMAIL="student@lms.local"
STUDENT_SEED_PASSWORD=
