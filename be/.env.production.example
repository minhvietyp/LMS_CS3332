DATABASE_URL="postgresql://lms_user:CHANGE_ME@postgres:5432/lms_db?schema=public"
PORT=3000
NODE_ENV=production
APP_VERSION=1.0.0
LOG_LEVEL=info
SLOW_REQUEST_THRESHOLD_MS=1000

JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_NAME=refresh_token
COOKIE_DOMAIN=
BCRYPT_ROUNDS=12

CORS_ORIGINS=https://your-domain.example
FRONTEND_URL=https://your-domain.example
TRUST_PROXY=true
JSON_BODY_LIMIT=100kb

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_STRICT_WINDOW_MS=900000
AUTH_STRICT_MAX=10
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_RATE_LIMIT_MAX=120

CACHE_ENABLED=true
PUBLIC_CACHE_TTL_MS=60000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@your-domain.example
